#!/bin/zsh
# Clone a repo as a bare repo.
#
# Works with `git worktree-add` to enforce a repo folder structure
# that accommodates worktrees:
#
#   $root_path/
#   ├── .git/              <- bare repo (created by clone-bare)
#   ├── feature-a/         <- worktree (created by worktree-add)
#   └── feature-b/         <- worktree (created by worktree-add)
#
# Usage: git clone-bare <repo_url> <root_path>

set -e

if [[ $# -ne 2 ]]; then
    echo "Usage: $0 <repo_url> <root_path>"
    echo "Example: $0 git@github.com:user/my-project.git \$HOME/code/my-project"
    exit 1
fi

REPO_URL=$1
ROOT_PATH=$2

BARE_DIR="${ROOT_PATH}/.git"

if [[ -d "$BARE_DIR" ]]; then
    echo "Bare repo already exists at ${BARE_DIR}, skipping clone."
else
    mkdir -p "${ROOT_PATH}"
    git clone --bare "$REPO_URL" "$BARE_DIR"
    # In a normal clone, git separates refs into:
    #   - refs/heads/* (local branches)
    #   - refs/remotes/origin/* (remote tracking branches)
    #
    # A bare repo was designed to be a server-side mirror - the central repo that
    # people push to and pull from. There's no local/remote distinction because every
    # branch *is* the authoritative copy. So `git clone --bare` maps everything
    # into refs/heads/* with fetch = +refs/heads/*:refs/heads/*.
    #
    # The worktree-based workflow repurposes bare repos for local development,
    # so we need the local/remote separation back. Fix the fetch refspec to
    # use the standard refs/remotes/origin/* namespace.
    git -C "$BARE_DIR" config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'

    # bare clone creates local branches for every remote branch.
    # Remove all local branches except the default, then re-fetch into
    # refs/remotes/origin/* using the corrected refspec.
    DEFAULT_BRANCH=$(git -C "$BARE_DIR" symbolic-ref --short HEAD)
    git -C "$BARE_DIR" for-each-ref --format='%(refname:short)' refs/heads/ \
        | grep -v "^${DEFAULT_BRANCH}$" \
        | xargs -r git -C "$BARE_DIR" branch -D 2>/dev/null || true
    git -C "$BARE_DIR" fetch origin
fi
