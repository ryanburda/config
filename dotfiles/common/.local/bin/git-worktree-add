#!/bin/zsh
# Add a worktree and run project-specific setup.
#
# Works with `git clone-bare` to enforce a repo folder structure
# that accommodates worktrees:
#
#   $root_path/
#   ├── .git/              <- bare repo (created by clone-bare)
#   ├── feature-a/         <- worktree (created by worktree-add)
#   └── feature-b/         <- worktree (created by worktree-add)
#
# The worktree is created as a sibling of the .git bare repo directory,
# regardless of where the command is run from within the repo.
#
# If a .worktree/setup script exists in the project root, it is executed
# from within the new worktree after creation.
#
# Prints the absolute path of the created worktree on success.
#
# Usage:
#   git worktree-add wt1 main          # checkout main in $root_path/wt1
#   git worktree-add wt1 main feature  # create branch "feature" off main in $root_path/wt1
#
# Using `git clone-bare` and `git worktree-add` together:
# ``` sh
# REPO_ROOT=~/code/project_a
# git clone-bare git@github.com:user/project_a.git "$REPO_ROOT"
# WT=$(git -C "$REPO_ROOT" worktree-add project_a main)
# git -C "$REPO_ROOT" worktree lock "$WT"  # Lock the worktree (optional)
# ```

set -e

if [[ $# -lt 2 || $# -gt 3 ]]; then
    echo "Usage: git worktree-add <worktree_name> <branch> [<new_branch>]"
    exit 1
fi

WORKTREE_NAME=$1
BRANCH=$2
NEW_BRANCH=$3

if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Error: not inside a git repository"
    exit 1
fi

BARE_DIR=$(cd "$(git rev-parse --git-common-dir)" && pwd)
PROJECT_ROOT="${BARE_DIR%/.git}"
WORKTREE_PATH="${PROJECT_ROOT}/${WORKTREE_NAME}"

if [[ -d "$WORKTREE_PATH" ]]; then
    echo "Error: ${WORKTREE_PATH} already exists"
    exit 1
fi

if [[ -n "$NEW_BRANCH" ]]; then
    git worktree add -b "$NEW_BRANCH" "$WORKTREE_PATH" "$BRANCH" >&2
else
    git worktree add "$WORKTREE_PATH" "$BRANCH" >&2
fi

SETUP_SCRIPT="${PROJECT_ROOT}/.worktree/setup"

if [[ -f "$SETUP_SCRIPT" ]]; then
    (cd "$WORKTREE_PATH" && exec "$SETUP_SCRIPT") >&2
fi

echo "$WORKTREE_PATH"
