#!/bin/zsh
# Add a worktree and run project-specific setup.
#
# Works with `git clone-bare` to enforce a repo folder structure
# that accommodates worktrees:
#
#   $root_path/
#   ├── .git/              <- bare repo (created by clone-bare)
#   ├── feature-a/         <- worktree (created by worktree-add)
#   └── feature-b/         <- worktree (created by worktree-add)
#
# The worktree is created at ../<worktree_name> relative to the current
# directory, enforcing the sibling layout above.
#
# If a .worktree/setup script exists in the project root, it is executed
# from within the new worktree after creation.
#
# Usage:
#   git worktree-add main                    # checkout main in ../main
#   git worktree-add main feature            # create branch "feature" off main in ../feature
#   git worktree-add -l main                 # checkout main in ../main and lock
#   git worktree-add -l main feature         # create branch "feature" off main in ../feature and lock

set -e

LOCK=false
if [[ "$1" == "-l" ]]; then
    LOCK=true
    shift
fi

if [[ $# -lt 1 || $# -gt 2 ]]; then
    echo "Usage: git worktree-add [-l] <branch> [<new_branch>]"
    exit 1
fi

BRANCH=$1
NEW_BRANCH=$2

if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Error: not inside a git repository"
    exit 1
fi

if [[ -n "$NEW_BRANCH" ]]; then
    WORKTREE_NAME=$NEW_BRANCH
else
    WORKTREE_NAME=$BRANCH
fi

WORKTREE_PATH="../${WORKTREE_NAME}"

if [[ -d "$WORKTREE_PATH" ]]; then
    echo "Error: ${WORKTREE_PATH} already exists"
    exit 1
fi

if [[ -n "$NEW_BRANCH" ]]; then
    git worktree add -b "$NEW_BRANCH" "$WORKTREE_PATH" "$BRANCH"
else
    git worktree add "$WORKTREE_PATH" "$BRANCH"
fi

if [[ "$LOCK" == true ]]; then
    git worktree lock "$WORKTREE_PATH"
fi

BARE_DIR=$(cd "$(git rev-parse --git-common-dir)" && pwd)
PROJECT_ROOT="${BARE_DIR%/.git}"
SETUP_SCRIPT="${PROJECT_ROOT}/.worktree/setup"

if [[ -f "$SETUP_SCRIPT" ]]; then
    (cd "$WORKTREE_PATH" && exec "$SETUP_SCRIPT")
fi
