#!/bin/zsh
# Add a worktree and run project-specific setup.
# Invoked as: git worktree-add <worktree_name> <branch> [<new_branch>]
#
# The worktree is created at ../<worktree_name> relative to the current
# directory, enforcing the sibling layout established by git-clone-bare.
#
# If a .worktree/setup script exists in the project root, it is executed
# from within the new worktree after creation.
#
# Usage:
#   git worktree-add wt1 main          # checkout main in ../wt1
#   git worktree-add wt1 main feature  # create branch "feature" off main in ../wt1

set -e

if [[ $# -lt 2 || $# -gt 3 ]]; then
    echo "Usage: git worktree-add <worktree_name> <branch> [<new_branch>]"
    exit 1
fi

WORKTREE_NAME=$1
BRANCH=$2
NEW_BRANCH=$3

if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Error: not inside a git repository"
    exit 1
fi

WORKTREE_PATH="../${WORKTREE_NAME}"

if [[ -d "$WORKTREE_PATH" ]]; then
    echo "Error: ${WORKTREE_PATH} already exists"
    exit 1
fi

if [[ -n "$NEW_BRANCH" ]]; then
    git worktree add -b "$NEW_BRANCH" "$WORKTREE_PATH" "$BRANCH"
else
    git worktree add "$WORKTREE_PATH" "$BRANCH"
fi

BARE_DIR=$(cd "$(git rev-parse --git-common-dir)" && pwd)
PROJECT_ROOT="${BARE_DIR%/.git}"
SETUP_SCRIPT="${PROJECT_ROOT}/.worktree/setup"

if [[ -f "$SETUP_SCRIPT" ]]; then
    (cd "$WORKTREE_PATH" && exec "$SETUP_SCRIPT")
fi
