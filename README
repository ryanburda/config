ln -sf ~/Developer/config/.bash_profile ~/.bash_profile
ln -sf ~/Developer/config/.zshrc ~/.zshrc
ln -sf ~/Developer/config/.direnvrc ~/.direnvrc
ln -sf ~/Developer/config/karabiner.json ~/.config/karabiner/karabiner.json
