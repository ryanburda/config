syntax enable
colorscheme desert

set tabstop=4 softtabstop=0 expandtab shiftwidth=4 smarttab
set encoding=utf-8

set relativenumber
set number
highlight LineNr ctermfg=grey

set colorcolumn=120
highlight ColorColumn ctermbg=DarkGrey

set nowrap

set whichwrap+=>,l
set whichwrap+=<,h
set whichwrap+=[,]

set mouse=a
set hlsearch

set clipboard=unnamed
